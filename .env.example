# ===========================================
# AI Provenance System - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env to version control.

# ===========================================
# Blockchain Relay Configuration
# ===========================================

# Backend relay wallet private key (WITHOUT 0x prefix).
# This wallet is granted registrar / writer permissions and pays gas for
# registerModelFor(...) and verifier-gated provenance writes.
PRIVATE_KEY=your_wallet_private_key_here

# Optional secondary wallet for tests or local experiments.
PRIVATE_KEY_B=your_secondary_private_key_here

# ===========================================
# Network RPC URLs
# ===========================================

SEPOLIA_URL=https://rpc.sepolia.org
BNB_TESTNET_URL=https://bsc-testnet.publicnode.com

# ===========================================
# IPFS / Pinata
# ===========================================

PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET=your_pinata_secret_key

# ===========================================
# Backend Server Configuration
# ===========================================

PORT=3000
CLIENT_URL=http://localhost:5173

# JWT secret used by /api/auth/login and protected backend routes.
# Required for any demo, shared, or production-like environment.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Optional auth token lifetime in seconds (default: 43200 / 12h).
AUTH_TOKEN_TTL_SECONDS=43200

# Optional file-backed auth store location. Defaults to server/data/auth_store.json.
AUTH_USER_STORE_FILE=server/data/auth_store.json

# Optional auth policy settings.
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_DURATION_SECONDS=900
AUTH_TOKEN_ISSUER=ai-provenance-backend
AUTH_TOKEN_AUDIENCE=ai-provenance-sdk

# ===========================================
# Frontend
# ===========================================

# Optional frontend API override. The browser no longer uses a public write key.
VITE_API_URL=http://127.0.0.1:3000

# ===========================================
# SDK Convenience Variables
# ===========================================

# These are optional helpers for local SDK runs. If omitted, the SDK can still
# log in when the caller passes username/password directly.
SDK_USERNAME=researcher
SDK_PASSWORD=researcher-demo-pass

# ===========================================
# Notes
# ===========================================
#
# 1. On the first backend boot, the server seeds server/data/auth_store.json with a
#    demo account:
#      username: researcher
#      password: researcher-demo-pass
#      wallet:   0x1111111111111111111111111111111111111111
#
# 2. The browser is presentation-only for status / registry / audit views and
#    authenticated lifecycle downloads. Training-time writes are expected to go
#    through the Python SDK, not a frontend API key.
#
# 3. Never:
#    - commit .env to git
#    - share private keys or Pinata credentials
#    - use real funds on the published testnet examples
#    - leave JWT_SECRET unset in a shared or presentation environment
#
# ===========================================
