# ===========================================
# AI Provenance System - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!

# ===========================================
# Blockchain Configuration (REQUIRED)
# ===========================================

# Deployer wallet private key (WITHOUT 0x prefix)
# WARNING: This key has control over your smart contracts!
# - Never share this key
# - Never commit .env to git
# - Use a separate wallet for deployments, not your main wallet
PRIVATE_KEY=your_wallet_private_key_here

# Secondary wallet (for multi-sig or testing)
PRIVATE_KEY_B=your_secondary_private_key_here

# ===========================================
# Network RPC URLs
# ===========================================

# Sepolia Testnet RPC (Ethereum)
# Options: Infura, Alchemy, or public RPCs
SEPOLIA_URL=https://rpc.sepolia.org

# BSC Testnet RPC
BNB_TESTNET_URL=https://bsc-testnet.publicnode.com

# ===========================================
# API Keys (Optional but Recommended)
# ===========================================

# Infura API Key (for Sepolia)
# Get free at: https://www.infura.io/
INFURA_API_KEY=your_infura_api_key_here

# Pinata API Key (for IPFS uploads)
# Get free at: https://pinata.cloud/
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET=your_pinata_secret_key

# ===========================================
# Server Configuration
# ===========================================

# Backend server port (default: 3000)
PORT=3000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Backend write protection
# Required for POST /api/register, /api/audit, /api/sdk/provenance, and IPFS upload routes
WRITE_API_KEY=replace_with_a_long_random_string

# Optional frontend dev key for local builds only
VITE_WRITE_API_KEY=replace_with_same_dev_key_for_local_frontend

# ===========================================
# Security Notes
# ===========================================
# 
# 1. Private Keys:
#    - Use a SEPARATE wallet for deployments, not your main wallet
#    - Enable 2FA on your wallet
#    - Set up spending limits if supported
#
# 2. API Keys:
#    - Use testnet RPCs for development
#    - Consider using multiple API keys for rate limiting
#    - Monitor usage and rotate keys regularly
#
# 3. Never:
#    - Commit .env to git
#    - Share credentials in screenshots
#    - Use real funds on testnets
#
# ===========================================
